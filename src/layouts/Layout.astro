---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'it' | 'en' | 'ar';
  dir?: 'ltr' | 'rtl';
  canonical?: string;
  ogLocale?: string;
  alternates?: { it: string; en: string; ar: string };
  extraStructuredData?: Record<string, unknown>;
  ogType?: string;
  ogImage?: string;
  articlePublishedTime?: string;
  articleAuthor?: string;
}

const SITE_URL = 'https://www.cantieri.ai';

const {
  title = 'Cantieri AI — Software Gestione Cantieri Edili',
  description = 'Cantieri AI: software per gestione cantieri edili. Rapportini digitali, SAL, documenti, dashboard in tempo reale e collaborazione multi-azienda. Prova gratis.',
  lang = 'it',
  dir = 'ltr',
  canonical = `${SITE_URL}/`,
  ogLocale = 'it_IT',
  alternates,
  extraStructuredData,
  ogType = 'website',
  ogImage,
  articlePublishedTime,
  articleAuthor,
} = Astro.props;

// Fallback: se non passati, puntano alla homepage (comportamento originale)
const hreflangs = alternates ?? {
  it: `${SITE_URL}/`,
  en: `${SITE_URL}/en/`,
  ar: `${SITE_URL}/ar/`,
};

const ogImageAlt: Record<string, string> = {
  it: 'Cantieri AI — Piattaforma di gestione cantieri edili',
  en: 'Cantieri AI — Construction Site Management Platform',
  ar: 'Cantieri AI — منصة إدارة مواقع البناء',
};

const alternateLocales: Record<string, string> = {
  it_IT: 'en_US',
  en_US: 'it_IT',
  ar_SA: 'it_IT',
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Search Console -->
    <meta name="google-site-verification" content="bIkMgBJi4mtIKnMK96RFFTvlih7nn9mMAsQ9odqJvqs" />

    <!-- SEO Base -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Cantieri AI" />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Cantieri AI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage ?? `${SITE_URL}/images/og_image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt[lang] ?? ogImageAlt.it} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content="it_IT" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="ar_SA" />

    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage ?? `${SITE_URL}/images/og_image.jpg`} />
    <meta name="twitter:image:alt" content={ogImageAlt[lang] ?? ogImageAlt.it} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="it" href={hreflangs.it} />
    <link rel="alternate" hreflang="en" href={hreflangs.en} />
    <link rel="alternate" hreflang="ar" href={hreflangs.ar} />
    <link rel="alternate" hreflang="x-default" href={hreflangs.it} />

    <!-- Preconnect & Fonts (non-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      />
    </noscript>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="theme-color" content="#F28F16" />

    <!-- Web App Manifest -->
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Cantieri AI",
      "alternateName": ["Cantieri", "Cantieri.ai", "Cantieri AI"],
      "description": "Software gestionale per cantieri edili: rapportini digitali, SAL, documenti di cantiere, dashboard in tempo reale e collaborazione multi-azienda. App cloud per imprese edili.",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Construction Management Software",
      "operatingSystem": "Web",
      "url": SITE_URL,
      "image": `${SITE_URL}/images/logo.png`,
      "keywords": "software gestione cantieri, gestionale cantiere edile, rapportini digitali cantiere, app cantiere, SAL digitale, software edilizia cloud",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR",
        "description": "Prova gratuita 14 giorni"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Cantieri AI",
        "alternateName": ["Cantieri", "Cantieri.ai", "Cantieri AI"],
        "url": SITE_URL,
        "logo": {
          "@type": "ImageObject",
          "url": `${SITE_URL}/images/logo.png`
        }
      }
    })} />
    {extraStructuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(extraStructuredData)} />
    )}
  </head>
  <body class="min-h-screen bg-slate-50 antialiased">
    <slot />
  </body>
</html>
