---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const plans = [
  {
    name: t(lang, 'pricing.base_name'),
    price: t(lang, 'pricing.base_price'),
    period: t(lang, 'pricing.base_period'),
    description: t(lang, 'pricing.base_desc'),
    features: [
      t(lang, 'pricing.base_f1'),
      t(lang, 'pricing.base_f2'),
      t(lang, 'pricing.base_f3'),
      t(lang, 'pricing.base_f4'),
    ],
    cta: t(lang, 'pricing.cta'),
    popular: false,
  },
  {
    name: t(lang, 'pricing.pro_name'),
    price: t(lang, 'pricing.pro_price'),
    period: t(lang, 'pricing.pro_period'),
    description: t(lang, 'pricing.pro_desc'),
    features: [
      t(lang, 'pricing.pro_f1'),
      t(lang, 'pricing.pro_f2'),
      t(lang, 'pricing.pro_f3'),
      t(lang, 'pricing.pro_f4'),
      t(lang, 'pricing.pro_f5'),
    ],
    cta: t(lang, 'pricing.cta'),
    popular: true,
  },
  {
    name: t(lang, 'pricing.enterprise_name'),
    price: t(lang, 'pricing.enterprise_price'),
    period: t(lang, 'pricing.enterprise_period'),
    description: t(lang, 'pricing.enterprise_desc'),
    features: [
      t(lang, 'pricing.enterprise_f1'),
      t(lang, 'pricing.enterprise_f2'),
      t(lang, 'pricing.enterprise_f3'),
      t(lang, 'pricing.enterprise_f4'),
      t(lang, 'pricing.enterprise_f5'),
    ],
    cta: t(lang, 'pricing.cta_enterprise'),
    popular: false,
  },
];
---

<section id="pricing" class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        {t(lang, 'pricing.title')}
      </h2>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        {t(lang, 'pricing.subtitle')}
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-lg grid-cols-1 gap-8 lg:max-w-none lg:grid-cols-3">
      {plans.map((plan) => (
        <div
          class:list={[
            'flex flex-col rounded-2xl p-8 ring-1 shadow-sm',
            plan.popular
              ? 'bg-slate-800 ring-slate-800 shadow-xl scale-105'
              : 'bg-white ring-slate-200',
          ]}
        >
          <div class="flex items-center justify-between gap-x-4">
            <h3
              class:list={[
                'text-lg font-semibold leading-8',
                plan.popular ? 'text-white' : 'text-slate-900',
              ]}
            >
              {plan.name}
            </h3>
            {plan.popular && (
              <span class="rounded-full bg-primary-500 px-2.5 py-1 text-xs font-semibold text-white">
                {t(lang, 'pricing.popular')}
              </span>
            )}
          </div>
          <p class:list={['mt-2 text-sm leading-6', plan.popular ? 'text-slate-300' : 'text-slate-600']}>
            {plan.description}
          </p>
          <div class="mt-6 flex items-baseline gap-x-1">
            <span
              class:list={[
                'text-4xl font-bold tracking-tight',
                plan.popular ? 'text-white' : 'text-slate-900',
              ]}
            >
              {plan.price}
            </span>
            {plan.period && (
              <span class:list={['text-sm leading-6', plan.popular ? 'text-slate-300' : 'text-slate-600']}>
                {plan.period}
              </span>
            )}
          </div>
          <ul
            class:list={[
              'mt-8 space-y-3 text-sm leading-6',
              plan.popular ? 'text-slate-300' : 'text-slate-600',
            ]}
          >
            {plan.features.map((feature) => (
              <li class="flex gap-x-3">
                <svg
                  class:list={[
                    'h-5 w-5 flex-none',
                    plan.popular ? 'text-primary-400' : 'text-primary-600',
                  ]}
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                    clip-rule="evenodd"
                  />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <a
            href="https://app.cantieri.ai/login"
            class:list={[
              'mt-8 block rounded-lg px-3.5 py-2.5 text-center text-sm font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2',
              plan.popular
                ? 'bg-primary-500 text-white hover:bg-primary-600 focus-visible:outline-primary-500'
                : 'bg-slate-50 text-slate-900 ring-1 ring-inset ring-slate-200 hover:bg-slate-100',
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
