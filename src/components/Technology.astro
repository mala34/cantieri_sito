---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="bg-white py-24 sm:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-x-16 gap-y-16 lg:grid-cols-2">
      <!-- Left: Text content -->
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-[#203044] sm:text-4xl">
          {t(lang, 'technology.title_light')}
          <br />
          <span class="bg-primary-500 bg-clip-text text-transparent">
            {t(lang, 'technology.title_accent')}
          </span>
        </h2>
        <p class="mt-6 text-lg font-medium leading-8 text-[#203044]/70">
          {t(lang, 'technology.subtitle')}
        </p>

        <div class="mt-12 space-y-8">
          <!-- Compliance -->
          <div class="flex gap-x-5">
            <div class="flex-none">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#E6E8EA]">
                <img src="/homepage/icon_compliance.svg" alt="" class="h-6 w-6 " aria-hidden="true" />
              </span>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-[#203044]">
                {t(lang, 'technology.compliance_title')}
              </h3>
              <p class="mt-2 text-base font-medium text-[#203044]/70">
                {t(lang, 'technology.compliance_desc')}
              </p>
            </div>
          </div>

          <!-- Templates -->
          <div class="flex gap-x-5">
            <div class="flex-none">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#E6E8EA]">
                <img src="/homepage/icon_template.svg" alt="" class="h-6 w-6" aria-hidden="true" />
              </span>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-[#203044]">
                {t(lang, 'technology.templates_title')}
              </h3>
              <p class="mt-2 text-base font-medium text-[#203044]/70">
                {t(lang, 'technology.templates_desc')}
              </p>
            </div>
          </div>

          <!-- Cloud AWS -->
          <div class="flex gap-x-5">
            <div class="flex-none">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#E6E8EA]">
                <img src="/homepage/icon_archiviazione.svg" alt="" class="h-6 w-6" aria-hidden="true" />
              </span>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-[#203044]">
                {t(lang, 'technology.cloud_title')}
              </h3>
              <p class="mt-2 text-base font-medium text-[#203044]/70">
                {t(lang, 'technology.cloud_desc')}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="relative">
        <div aria-hidden="true" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[32rem] h-[32rem] rounded-full bg-primary-500/20 blur-3xl pointer-events-none"></div>
        <div class="relative w-full max-w-[692px] mx-auto lg:mx-0 lg:ms-auto">
          <img
            src="/homepage/WorkerMobile.png"
            alt="Cantieri Worker Mobile"
            width="512"
            height="512"
            class="relative w-full rounded-[40px]"
          />
          <!-- Floating card -->
          <div class="absolute bottom-[4.62%] left-[4.62%] right-[4.62%] rounded-2xl bg-white shadow-[0_20px_50px_-10px_rgba(32,48,68,0.25)] p-4 sm:p-5">
            <div class="flex items-center gap-3 sm:gap-4">
              <span class="flex h-10 w-10 sm:h-12 sm:w-12 flex-none items-center justify-center rounded-full bg-[#DCFCE7]">
                <img src="/homepage/icon_message.svg" alt="" class="h-5 w-5 sm:h-6 sm:w-6" aria-hidden="true" />
              </span>
              <div class="min-w-0 flex-1">
                <p class="text-xs font-medium uppercase tracking-wide text-[#64748B]">
                  {t(lang, 'technology.card_label')}
                </p>
                <p class="mt-1 text-sm font-semibold text-[#191C1E]">
                  {t(lang, 'technology.card_quote')}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
