---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const solutions = [
  {
    title: t(lang, 'solutions.residential_title'),
    description: t(lang, 'solutions.residential_desc'),
    icon: 'home',
  },
  {
    title: t(lang, 'solutions.commercial_title'),
    description: t(lang, 'solutions.commercial_desc'),
    icon: 'building',
  },
  {
    title: t(lang, 'solutions.infrastructure_title'),
    description: t(lang, 'solutions.infrastructure_desc'),
    icon: 'road',
  },
  {
    title: t(lang, 'solutions.renovation_title'),
    description: t(lang, 'solutions.renovation_desc'),
    icon: 'wrench',
  },
];
---

<section id="solutions" class="bg-slate-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
        {t(lang, 'solutions.title')}
      </h2>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        {t(lang, 'solutions.subtitle')}
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 sm:grid-cols-2 lg:max-w-none lg:grid-cols-4">
      {solutions.map((solution) => (
        <div class="group relative rounded-2xl bg-white p-5 sm:p-8 shadow-sm ring-1 ring-slate-200 hover:shadow-lg hover:ring-primary-200 transition-all">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-50 group-hover:bg-primary-100 transition-colors">
            {solution.icon === 'home' && (
              <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
            )}
            {solution.icon === 'building' && (
              <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
              </svg>
            )}
            {solution.icon === 'road' && (
              <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
              </svg>
            )}
            {solution.icon === 'wrench' && (
              <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
              </svg>
            )}
          </div>
          <h3 class="mt-6 text-lg font-semibold text-slate-900">
            {solution.title}
          </h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            {solution.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
