---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="bg-slate-900 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white md:text-4xl">
        {t(lang, 'cta.title')}
      </h2>
      <p class="mt-4 text-lg leading-8 text-slate-300">
        {t(lang, 'cta.subtitle')}
      </p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a
          href="https://app.cantieri.ai/login"
          class="rounded-md bg-primary-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-600 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500 transition-colors"
        >
          {t(lang, 'cta.button')}
        </a>
        <a href="#" class="text-sm font-semibold text-white hover:text-primary-400 transition-colors">
          {t(lang, 'cta.button_secondary')} <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>
