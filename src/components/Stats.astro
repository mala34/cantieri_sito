---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const stats = [
  { value: t(lang, 'stats.sites_value'), label: t(lang, 'stats.sites_label') },
  { value: t(lang, 'stats.uptime_value'), label: t(lang, 'stats.uptime_label') },
  { value: t(lang, 'stats.companies_value'), label: t(lang, 'stats.companies_label') },
  { value: t(lang, 'stats.support_value'), label: t(lang, 'stats.support_label') },
];
---

<section class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <dl class="grid grid-cols-2 gap-x-4 gap-y-8 sm:gap-x-8 sm:gap-y-12 text-center lg:grid-cols-4">
      {stats.map((stat) => (
        <div class="flex flex-col gap-y-2">
          <dt class="text-sm leading-6 text-slate-600">{stat.label}</dt>
          <dd class="order-first text-2xl sm:text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
            {stat.value}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>
