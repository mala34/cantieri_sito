---
import { t, languages, localePath, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<nav class="fixed top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-slate-200/60">
  <div class="px-4 sm:px-6 lg:px-10">
    <div class="flex h-16 items-center justify-between">
      <a href={localePath(lang)} class="flex items-center gap-2">
        <img src="/images/logo.png" alt="Cantieri" class="h-8 w-auto" />
        <span class="text-lg font-bold text-slate-900">Cantieri</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href={`${localePath(lang)}#features`} class="text-sm font-medium text-slate-600 hover:text-primary-600 transition-colors">
          {t(lang, 'nav.features')}
        </a>
        <a href={`${localePath(lang)}#pricing`} class="text-sm font-medium text-slate-600 hover:text-primary-600 transition-colors">
          {t(lang, 'nav.pricing')}
        </a>
        <a href={`${localePath(lang)}#solutions`} class="text-sm font-medium text-slate-600 hover:text-primary-600 transition-colors">
          {t(lang, 'nav.solutions')}
        </a>
        <div class="flex items-center gap-1">
          {Object.entries(languages).map(([code, label]) => (
            <a
              href={localePath(code as Lang)}
              class:list={[
                'text-xs px-2 py-1 rounded-md transition-colors',
                code === lang ? 'bg-primary-500 text-white' : 'text-slate-500 hover:text-slate-900 hover:bg-slate-100',
              ]}
            >
              {code.toUpperCase()}
            </a>
          ))}
        </div>
        <a
          href="https://app.cantieri.ai/login"
          class="rounded-md bg-primary-500 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary-600 transition-colors"
        >
          {t(lang, 'nav.login')}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600" aria-label="Menu">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200/60 bg-white/95 backdrop-blur-md">
    <div class="px-6 py-4 space-y-3">
      <a href={`${localePath(lang)}#features`} class="block text-sm font-medium text-slate-600">
        {t(lang, 'nav.features')}
      </a>
      <a href={`${localePath(lang)}#pricing`} class="block text-sm font-medium text-slate-600">
        {t(lang, 'nav.pricing')}
      </a>
      <a href={`${localePath(lang)}#solutions`} class="block text-sm font-medium text-slate-600">
        {t(lang, 'nav.solutions')}
      </a>
      <div class="flex items-center gap-2">
        {Object.entries(languages).map(([code, label]) => (
          <a
            href={localePath(code as Lang)}
            class:list={[
              'text-xs px-2 py-1 rounded-md',
              code === lang ? 'bg-primary-500 text-white' : 'text-slate-500 hover:bg-slate-100',
            ]}
          >
            {code.toUpperCase()}
          </a>
        ))}
      </div>
      <a
        href="https://app.cantieri.ai/login"
        class="block rounded-md bg-primary-500 px-4 py-2 text-sm font-semibold text-white text-center"
      >
        {t(lang, 'nav.login')}
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
