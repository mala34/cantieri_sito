---
import { formatDate } from "../../lib/posts";
import { getCategoriaLabel } from "../../lib/categories";

interface Props {
  title: string;
  slug: string;
  categoria: string;
  date: Date;
  description?: string | null;
  image?: string | null;
  author?: string | null;
}

const { title, slug, categoria, date, description, image, author } = Astro.props;
const href = `/blog/${slug}/`;
---

<article data-post-card data-categoria={categoria} class="group flex flex-col rounded-2xl bg-white shadow-[0_1px_6px_rgba(32,48,68,0.06)] hover:shadow-[0_4px_16px_rgba(32,48,68,0.10)] transition-shadow duration-200 overflow-hidden">
  {image && (
    <a href={href} class="block overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </a>
  )}
  <div class="flex flex-col grow p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-primary-50 text-primary-700">
        {getCategoriaLabel(categoria)}
      </span>
    </div>
    <h3 class="text-lg font-semibold text-slate-800 mb-2 leading-snug">
      <a href={href} class="hover:text-primary-600 transition-colors">
        {title}
      </a>
    </h3>
    {description && (
      <p class="text-sm font-medium text-slate-500 mb-4 line-clamp-3 grow">{description}</p>
    )}
    <div class="flex items-center gap-3 text-xs text-slate-400 mt-auto pt-4 border-t border-slate-100">
      <time datetime={date.toISOString()}>
        {formatDate(date)}
      </time>
      {author && (
        <>
          <span class="w-1 h-1 rounded-full bg-slate-300"></span>
          <span>{author}</span>
        </>
      )}
    </div>
  </div>
</article>
