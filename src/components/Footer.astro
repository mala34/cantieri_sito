---
import { t, localePath, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-slate-800 text-slate-400">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={localePath(lang)} class="flex items-center gap-2">
          <img src="/images/logo.png" alt="Cantieri AI logo" width="266" height="276" class="h-8 w-auto brightness-200" />
          <img src="/images/logo_cantieri.png" alt="Cantieri AI" width="691" height="158" class="h-5 w-auto" />
        </a>
        <p class="mt-4 text-sm leading-6">
          {t(lang, 'footer.description')}
        </p>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-sm font-semibold text-white">{t(lang, 'footer.product')}</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href={`${localePath(lang)}#features`} class="text-sm hover:text-white transition-colors">
              {t(lang, 'nav.features')}
            </a>
          </li>
          <li>
            <a href={`${localePath(lang)}#solutions`} class="text-sm hover:text-white transition-colors">
              {t(lang, 'nav.solutions')}
            </a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-white">{t(lang, 'footer.company')}</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href={lang === 'it' ? '/blog/' : `/${lang}/blog/`} class="text-sm hover:text-white transition-colors">
              {t(lang, 'footer.blog')}
            </a>
          </li>
          <li>
            <a href={lang === 'it' ? '/contattaci' : lang === 'en' ? '/en/contact' : '/ar/contact'} class="text-sm hover:text-white transition-colors">
              {t(lang, 'footer.contact')}
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Legal info -->
    <div class="mt-12 border-t border-slate-700/50 pt-8">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-slate-500">
        <div class="flex flex-col items-center gap-1.5 sm:flex-row sm:gap-4 text-center">
          <span>Piazza Sergio Finocchi, 3 — 41017 Spilamberto (MO)</span>
          <span class="hidden sm:inline">·</span>
          <a href="tel:+393480407500" class="hover:text-white transition-colors">Tel. 348.0407500</a>
          <span class="hidden sm:inline">·</span>
          <a href="mailto:info@cantieri.ai" class="hover:text-white transition-colors">info@cantieri.ai</a>
          <span class="hidden sm:inline">·</span>
          <span>P.IVA: 03447571203</span>
        </div>
      </div>
      <p class="mt-4 text-xs text-slate-500 text-center">
        &copy; {year} Cantieri. {t(lang, 'footer.rights')}
      </p>
    </div>
  </div>
</footer>
