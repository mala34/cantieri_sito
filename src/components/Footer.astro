---
import { t, localePath, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={localePath(lang)} class="flex items-center gap-2">
          <img src="/images/logo.png" alt="Cantieri" class="h-8 w-auto brightness-200" />
          <span class="text-lg font-bold text-white">Cantieri</span>
        </a>
        <p class="mt-4 text-sm leading-6">
          {t(lang, 'footer.description')}
        </p>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-sm font-semibold text-white">{t(lang, 'footer.product')}</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href={`${localePath(lang)}#features`} class="text-sm hover:text-white transition-colors">
              {t(lang, 'nav.features')}
            </a>
          </li>
          <li>
            <a href={`${localePath(lang)}#pricing`} class="text-sm hover:text-white transition-colors">
              {t(lang, 'nav.pricing')}
            </a>
          </li>
          <li>
            <a href={`${localePath(lang)}#solutions`} class="text-sm hover:text-white transition-colors">
              {t(lang, 'nav.solutions')}
            </a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-white">{t(lang, 'footer.company')}</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="#" class="text-sm hover:text-white transition-colors">
              {t(lang, 'footer.about')}
            </a>
          </li>
          <li>
            <a href="#" class="text-sm hover:text-white transition-colors">
              {t(lang, 'footer.blog')}
            </a>
          </li>
          <li>
            <a href="#" class="text-sm hover:text-white transition-colors">
              {t(lang, 'footer.contact')}
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold text-white">{t(lang, 'footer.legal')}</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="#" class="text-sm hover:text-white transition-colors">
              {t(lang, 'footer.privacy')}
            </a>
          </li>
          <li>
            <a href="#" class="text-sm hover:text-white transition-colors">
              {t(lang, 'footer.terms')}
            </a>
          </li>
          <li>
            <a href="#" class="text-sm hover:text-white transition-colors">
              {t(lang, 'footer.cookies')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 border-t border-slate-800 pt-8">
      <p class="text-sm text-center">
        &copy; {year} Cantieri. {t(lang, 'footer.rights')}
      </p>
    </div>
  </div>
</footer>
