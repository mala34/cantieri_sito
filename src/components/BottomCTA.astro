---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-16 sm:py-20 bg-slate-50">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-[40px] bg-slate-900 px-6 py-16 sm:px-16 sm:py-20 shadow-[30px_30px_60px_rgba(0,0,0,0.15),-30px_-30px_60px_rgba(0,0,0,0.15)]">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-base font-medium text-slate-300">
          {t(lang, 'cta.newsletter_lead')}
        </p>
        <p class="mt-2 text-sm font-medium text-slate-400">
          {t(lang, 'cta.newsletter_privacy')}
        </p>
        <h2 class="mt-6 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {t(lang, 'cta.newsletter_title')}
        </h2>
        <form class="mt-10 mx-auto flex max-w-md flex-col sm:flex-row items-stretch gap-3">
          <label class="sr-only" for="newsletter-email">{t(lang, 'cta.newsletter_placeholder')}</label>
          <input
            id="newsletter-email"
            type="email"
            required
            placeholder={t(lang, 'cta.newsletter_placeholder')}
            class="flex-1 min-w-0 rounded-md bg-white/5 px-4 py-3 text-sm font-medium text-white placeholder:text-slate-400 ring-1 ring-inset ring-white/20 focus:ring-2 focus:ring-primary-500 focus:outline-none transition-all"
          />
          <button
            type="submit"
            class="rounded-md bg-primary-500 px-6 py-3 text-sm font-semibold text-white shadow-[0_2px_8px_rgba(255,122,35,0.3)] hover:brightness-110 transition-all whitespace-nowrap"
          >
            {t(lang, 'cta.newsletter_button')}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
