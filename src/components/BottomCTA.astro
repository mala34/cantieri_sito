---
import { t, localePath, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const contactHref = localePath(lang, 'contattaci');
---

<section class="py-16 sm:py-20 bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl sm:rounded-[40px] bg-slate-800 px-4 py-12 sm:px-16 sm:py-20 shadow-[30px_30px_60px_rgba(0,0,0,0.15),-30px_-30px_60px_rgba(0,0,0,0.15)]">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white md:text-4xl">
          {t(lang, 'cta.bottom_title')}
        </h2>
        <p class="mt-4 text-lg font-medium text-slate-300">
          {t(lang, 'cta.bottom_subtitle')}
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={contactHref}
            class="rounded-md bg-primary-500 px-8 py-3 text-sm font-semibold text-white shadow-[0_2px_8px_rgba(32,48,68,0.08)] hover:bg-primary-600 transition-colors"
          >
            {t(lang, 'cta.bottom_button')}
          </a>
          <a
            href={`mailto:info@cantieri.ai`}
            class="text-sm font-medium text-slate-400 hover:text-primary-300 transition-colors"
          >
            {t(lang, 'cta.contact_or')}info@cantieri.ai
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
