---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import CategoryFilter from "../../components/blog/CategoryFilter.astro";
import PostCard from "../../components/blog/PostCard.astro";
import { getBlogPosts } from "../../lib/posts";
import { getAllCategories } from "../../lib/categories";

const lang = "it";
const allPosts = await getBlogPosts();
const allCategories = getAllCategories();

const usedCategories: Record<string, string> = {};
for (const post of allPosts) {
  const slug = post.data.categoria;
  if (allCategories[slug]) {
    usedCategories[slug] = allCategories[slug];
  }
}
---

<Layout
  lang={lang}
  title="Blog — Cantieri AI | Approfondimenti Edilizia Digitale"
  description="Articoli, guide e approfondimenti sulla digitalizzazione dei cantieri edili, normative, sicurezza e gestione dei progetti di costruzione."
  canonical="https://www.cantieri.ai/blog/"
  ogLocale="it_IT"
>
  <Navbar lang={lang} />
  <main class="min-h-screen bg-slate-50">
    <div class="mx-auto max-w-7xl px-4 pt-28 pb-16 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-sm font-semibold text-primary-500 tracking-wide uppercase">Blog</p>
        <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-slate-800">
          Blog
        </h1>
        <p class="mt-3 text-lg font-medium text-slate-500">
          Approfondimenti, guide e novita dal mondo dell'edilizia digitale.
        </p>
      </div>

      <div class="mb-6">
        <div class="relative max-w-md">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="absolute left-3 top-1/2 -translate-y-1/2 size-5 text-slate-400 pointer-events-none">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            type="text"
            id="search-input"
            placeholder="Cerca articoli..."
            class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-full bg-white focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all"
          />
        </div>
      </div>

      <CategoryFilter categories={usedCategories} />

      {allPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {allPosts.map((post) => (
            <PostCard
              title={post.data.title}
              slug={post.id}
              categoria={post.data.categoria}
              date={post.data.date}
              description={post.data.description}
              image={post.data.image}
              author={post.data.author}
            />
          ))}
        </div>
      ) : (
        <p class="text-slate-400 text-center py-16">Nessun articolo disponibile.</p>
      )}
    </div>
  </main>
  <Footer lang={lang} />
</Layout>

<script>
  const input = document.getElementById("search-input") as HTMLInputElement;
  const cards = document.querySelectorAll("[data-post-card]");

  input?.addEventListener("input", () => {
    const query = input.value.toLowerCase().trim();
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const text = el.textContent?.toLowerCase() ?? "";
      const hiddenByCat = el.dataset.hiddenByCategory === "true";
      const matchesSearch = !query || text.includes(query);
      el.dataset.hiddenBySearch = matchesSearch ? "false" : "true";
      el.style.display = matchesSearch && !hiddenByCat ? "" : "none";
    });
  });
</script>
