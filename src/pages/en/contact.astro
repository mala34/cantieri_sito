---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n';

const lang = 'en';
---

<Layout
  lang={lang}
  title="Contact Us — Cantieri AI | Construction Management"
  description="Contact the Cantieri AI team for info on construction site management software, request a demo or speak with an expert. We reply within 24h."
  canonical="https://www.cantieri.ai/en/contact"
  ogLocale="en_US"
  alternates={{
    it: 'https://www.cantieri.ai/contattaci',
    en: 'https://www.cantieri.ai/en/contact',
    ar: 'https://www.cantieri.ai/ar/contact',
  }}
  extraStructuredData={{
    '@context': 'https://schema.org',
    '@type': 'Organization',
    'name': 'Cantieri AI',
    'url': 'https://www.cantieri.ai',
    'logo': 'https://www.cantieri.ai/images/logo.png',
    'email': 'info@cantieri.ai',
    'telephone': '+393480407500',
    'address': {
      '@type': 'PostalAddress',
      'streetAddress': 'Piazza Sergio Finocchi, 3',
      'addressLocality': 'Spilamberto',
      'addressRegion': 'MO',
      'postalCode': '41017',
      'addressCountry': 'IT',
    },
    'contactPoint': {
      '@type': 'ContactPoint',
      'contactType': 'customer service',
      'email': 'info@cantieri.ai',
      'telephone': '+393480407500',
      'availableLanguage': ['Italian', 'English', 'Arabic'],
    },
  }}
>
  <Navbar lang={lang} />
  <main class="min-h-screen bg-slate-50">
    <div class="relative">
      <div class="lg:absolute lg:inset-0 lg:left-1/2">
        <img alt="Cantieri AI — Contact Us" src="/contacts/contattaci.jpg" class="h-64 w-full bg-slate-100 object-cover sm:h-80 lg:absolute lg:h-full" />
      </div>
      <div class="pt-24 pb-24 sm:pt-32 sm:pb-32 lg:mx-auto lg:grid lg:max-w-7xl lg:grid-cols-2 lg:pt-32">
        <div class="px-4 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-xl lg:mx-0 lg:max-w-lg">
            <p class="text-sm font-semibold text-primary-500 tracking-wide uppercase">
              {t(lang, 'contact.label')}
            </p>
            <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-slate-800 md:text-5xl">
              {t(lang, 'contact.title')}
            </h1>
            <p class="mt-4 text-lg font-medium text-slate-500">
              {t(lang, 'contact.subtitle')}
            </p>

            <form id="contact-form" class="mt-12">
              <input type="text" name="_honey" style="display:none" />

              <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
                <div>
                  <label for="nome" class="block text-sm font-semibold text-slate-700">
                    {t(lang, 'contact.name')} <span class="text-primary-500">*</span>
                  </label>
                  <div class="mt-2.5">
                    <input type="text" id="nome" name="nome" required autocomplete="given-name" placeholder={t(lang, 'contact.name_placeholder')} class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition-all" />
                  </div>
                </div>
                <div>
                  <label for="cognome" class="block text-sm font-semibold text-slate-700">
                    {t(lang, 'contact.surname')} <span class="text-primary-500">*</span>
                  </label>
                  <div class="mt-2.5">
                    <input type="text" id="cognome" name="cognome" required autocomplete="family-name" placeholder={t(lang, 'contact.surname_placeholder')} class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition-all" />
                  </div>
                </div>
                <div class="sm:col-span-2">
                  <label for="azienda" class="block text-sm font-semibold text-slate-700">{t(lang, 'contact.company')}</label>
                  <div class="mt-2.5">
                    <input type="text" id="azienda" name="azienda" autocomplete="organization" placeholder={t(lang, 'contact.company_placeholder')} class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition-all" />
                  </div>
                </div>
                <div class="sm:col-span-2">
                  <label for="email" class="block text-sm font-semibold text-slate-700">
                    {t(lang, 'contact.email')} <span class="text-primary-500">*</span>
                  </label>
                  <div class="mt-2.5">
                    <input type="email" id="email" name="email" required autocomplete="email" placeholder={t(lang, 'contact.email_placeholder')} class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition-all" />
                  </div>
                </div>
                <div class="sm:col-span-2">
                  <div class="flex justify-between text-sm">
                    <label for="telefono" class="block font-semibold text-slate-700">{t(lang, 'contact.phone')}</label>
                    <p class="text-slate-400 font-medium">{t(lang, 'contact.phone_optional')}</p>
                  </div>
                  <div class="mt-2.5 flex gap-3">
                    <div class="flex items-center px-4 py-3 rounded-xl border border-slate-200 bg-slate-100 text-slate-500 text-sm font-medium shrink-0">+39</div>
                    <div class="relative flex-1">
                      <input type="tel" id="telefono" name="telefono" maxlength="10" autocomplete="tel" placeholder={t(lang, 'contact.phone_placeholder')} pattern="[0-9]{0,10}" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition-all" />
                      <span id="char-count" class="absolute right-3 top-1/2 -translate-y-1/2 text-[11px] text-slate-400 font-medium">0 {t(lang, 'contact.phone_count')}</span>
                    </div>
                  </div>
                </div>
                <div class="sm:col-span-2">
                  <div class="flex justify-between text-sm">
                    <label for="messaggio" class="block font-semibold text-slate-700">{t(lang, 'contact.message')}</label>
                    <p class="text-slate-400 font-medium">{t(lang, 'contact.message_max')}</p>
                  </div>
                  <div class="mt-2.5">
                    <textarea id="messaggio" name="messaggio" rows="4" maxlength="500" placeholder={t(lang, 'contact.message_placeholder')} class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition-all resize-none"></textarea>
                  </div>
                </div>
              </div>

              <div class="mt-10 flex justify-end border-t border-slate-200 pt-8">
                <button id="submit-btn" type="submit" class="px-10 py-4 bg-primary-500 text-white font-semibold rounded-xl hover:bg-primary-600 shadow-[0_2px_8px_rgba(32,48,68,0.08)] transition-all cursor-pointer disabled:opacity-50 disabled:hover:brightness-100">
                  {t(lang, 'contact.submit')}
                </button>
              </div>
            </form>

            <div id="success-message" class="hidden mt-8 p-6 rounded-2xl bg-emerald-50 border border-emerald-200">
              <p class="text-emerald-700 font-semibold text-center">{t(lang, 'contact.success_title')}</p>
              <p class="text-emerald-600 text-sm mt-2 text-center">{t(lang, 'contact.success_desc')}</p>
            </div>
            <div id="error-message" class="hidden mt-8 p-6 rounded-2xl bg-red-50 border border-red-200">
              <p class="text-red-700 font-semibold text-center">{t(lang, 'contact.error_title')}</p>
              <p class="text-red-600 text-sm mt-2 text-center">{t(lang, 'contact.error_desc')} <a href="mailto:info@cantieri.ai" class="underline font-semibold">info@cantieri.ai</a></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>

<script>
  const phoneInput = document.getElementById('telefono') as HTMLInputElement;
  const charCount = document.getElementById('char-count');
  if (phoneInput && charCount) {
    const suffix = charCount.textContent?.replace(/^\d+\s*/, '') || '';
    phoneInput.addEventListener('input', () => {
      phoneInput.value = phoneInput.value.replace(/\D/g, '').slice(0, 10);
      charCount.textContent = `${phoneInput.value.length} ${suffix}`;
    });
  }
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('success-message')!;
  const errorMsg = document.getElementById('error-message')!;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    const formData = new FormData(form);
    if (formData.get('_honey')) return;
    const data = {
      nome: formData.get('nome'), cognome: formData.get('cognome'), azienda: formData.get('azienda') || 'Not provided', email: formData.get('email'),
      telefono: formData.get('telefono') ? `+39 ${formData.get('telefono')}` : 'Not provided',
      messaggio: formData.get('messaggio') || 'No message',
      _subject: 'New contact from Cantieri AI', _captcha: 'false', _template: 'table',
    };
    try {
      const response = await fetch('https://formsubmit.co/ajax/info@cantieri.ai', {
        method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });
      if (response.ok) {
        successMsg.classList.remove('hidden'); form.reset();
        if (charCount) { const s = charCount.textContent?.replace(/^\d+\s*/, '') || ''; charCount.textContent = `0 ${s}`; }
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else { throw new Error('Send error'); }
    } catch { errorMsg.classList.remove('hidden'); errorMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
    finally { submitBtn.disabled = false; submitBtn.textContent = originalText; }
  });
</script>
